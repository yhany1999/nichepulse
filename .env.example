# ─────────────────────────────────────────────
# YouTube Trending Tool — Environment Variables
# ─────────────────────────────────────────────
# 1. Copy this file to .env
# 2. Fill in your real values
# 3. Never commit .env — it is gitignored

# ── YouTube Data API v3 ──────────────────────
# Get from: https://console.cloud.google.com/apis/credentials
# Enable "YouTube Data API v3" in your Google Cloud project first.
YOUTUBE_API_KEY=your_youtube_api_key_here

# ── Gmail Email Delivery ─────────────────────
# GMAIL_APP_PASSWORD is a 16-char app password, NOT your Google account password.
# Generate at: https://myaccount.google.com/apppasswords
GMAIL_FROM=you@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
REPORT_EMAIL=you@gmail.com
